# Copy to `.env.local` in the project root (same folder as package.json). Required for PDF export.
# Vite only exposes variables prefixed with VITE_. Restart `npm run dev` after changes.

# PDF API: full URL ending in /pdf, or base URL (the app appends /pdf if missing).
# Local pdf-service:
# VITE_PDF_SERVICE_URL=http://localhost:3040
# Deployed:
# VITE_PDF_SERVICE_URL=https://your-pdf-api.example.com
